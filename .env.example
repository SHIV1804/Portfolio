# Resend API Key for sending emails
# Get one at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# The email address where you want to receive contact form submissions
CONTACT_EMAIL=your@email.com

# GitHub Personal Access Token (Classic or Fine-grained)
# Required for the GitHub activity dashboard.
# Get one at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Database
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# NextAuth
GITHUB_ID=your_github_oauth_client_id
GITHUB_SECRET=your_github_oauth_client_secret
NEXTAUTH_SECRET=your_nextauth_secret_at_least_32_chars
NEXTAUTH_URL=https://portfolio-theta-ruby-31nqvqjqmc.vercel.app
ADMIN_EMAIL=your-admin-email@example.com
